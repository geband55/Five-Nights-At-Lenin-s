    \xAB\u041B\u0435\u043D\u0444\u0438\u043B\u044C\u043C\xBB \u0435\u0451 \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u043B\u044F\u043B\u0438
    \u0440\u0430\u0437\u043D\u044B\u0435 \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u0430,
    \u0441\u044B\u0433\u0440\u0430\u0432\u0448\u0438\u0435 \u0432\u0430\u0436\u043D\u0443\u044E
    \u0440\u043E\u043B\u044C \u0432 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0438
    \u0441\u0442\u0443\u0434\u0438\u0438 \u0438 \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u043E\u0433\u043E
    \u043A\u0438\u043D\u0435\u043C\u0430\u0442\u043E\u0433\u0440\u0430\u0444\u0430.
    \u0412 1930-\u0435 \u0433\u043E\u0434\u044B \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u043C
    \u0441\u0442\u0443\u0434\u0438\u0438 \u0431\u044B\u043B \u041F\u0430\u0432\u0435\u043B
    \u041F\u0435\u0442\u0440\u043E\u0432-\u0411\u044B\u0442\u043E\u0432, \u043F\u043E\u0434
    \u0447\u044C\u0438\u043C \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C
    \u0441\u0442\u0443\u0434\u0438\u044F \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430
    \u0438\u043C\u044F \xAB\u041B\u0435\u043D\u0444\u0438\u043B\u044C\u043C\xBB \u0438
    \u043D\u0430\u0447\u0430\u043B\u0430 \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u0442\u044C\u0441\u044F. \u0412 \u043F\u043E\u0441\u043B\u0435\u0432\u043E\u0435\u043D\u043D\u044B\u0435
    \u0433\u043E\u0434\u044B \u0441\u0442\u0443\u0434\u0438\u0435\u0439 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u043B\u0438
    \u0418\u0432\u0430\u043D \u041F\u044B\u0440\u044C\u0435\u0432 \u0438 \u0434\u0440\u0443\u0433\u0438\u0435
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F \u0434\u0435\u044F\u0442\u0435\u043B\u0438,
    \u0443\u0434\u0435\u043B\u044F\u0432\u0448\u0438\u0435 \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435
    \u043A\u0430\u043A \u0438\u0434\u0435\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439,
    \u0442\u0430\u043A \u0438 \u0445\u0443\u0434\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u044E\u0449\u0435\u0439 \u0444\u0438\u043B\u044C\u043C\u043E\u0432.
    \u0412 1960\u20131980-\u0435 \u0433\u043E\u0434\u044B \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u0430\u043C\u0438
    \u0431\u044B\u043B\u0438 \u0411\u043E\u0440\u0438\u0441 \u041F\u0430\u0432\u043B\u0435\u043D\u043E\u043A
    \u0438 \u0418\u0433\u043E\u0440\u044C \u0412\u0438\u043D\u043E\u0433\u0440\u0430\u0434\u0441\u043A\u0438\u0439,
    \u043F\u0440\u0438 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \xAB\u041B\u0435\u043D\u0444\u0438\u043B\u044C\u043C\xBB
    \u0432\u044B\u043F\u0443\u0441\u0442\u0438\u043B \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u044B\u0445 \u043A\u0430\u0440\u0442\u0438\u043D.
    \u041F\u043E\u0441\u043B\u0435 \u0440\u0430\u0441\u043F\u0430\u0434\u0430 \u0421\u0421\u0421\u0420
    \u0441\u0442\u0443\u0434\u0438\u044F \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0430\u0441\u044C
    \u0441 \u0442\u0440\u0443\u0434\u043D\u043E\u0441\u0442\u044F\u043C\u0438, \u043D\u043E
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0430 \u0441\u0432\u043E\u044E
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0443\u0441\u0438\u043B\u0438\u044F\u043C \u043D\u043E\u0432\u044B\u0445 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u0439.
    \u0412 2011 \u0433\u043E\u0434\u0443 \u0441\u0442\u0443\u0434\u0438\u044E \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u0438\u043B
    \u042D\u0434\u0443\u0430\u0440\u0434 \u041F\u0438\u0447\u0443\u0433\u0438\u043D,
    \u0430 \u0432 2020-\u0435 \u0433\u0435\u043D\u0435\u0440\u0430\u043B\u044C\u043D\u044B\u043C
    \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u043E\u043C \u0441\u0442\u0430\u043B
    \u0424\u0451\u0434\u043E\u0440 \u0429\u0435\u0440\u0431\u0430\u043A\u043E\u0432.
    \u041A\u0430\u0436\u0434\u044B\u0439 \u0438\u0437 \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u043E\u0432
    \u0432\u043D\u0451\u0441 \u0432\u043A\u043B\u0430\u0434 \u0432 \u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u0435
    \u0438 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \xAB\u041B\u0435\u043D\u0444\u0438\u043B\u044C\u043C\u0430\xBB,
    \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432\u0430\u044F \u0435\u0433\u043E
    \u0430\u0434\u0430\u043F\u0442\u0430\u0446\u0438\u044E \u043A \u043C\u0435\u043D\u044F\u044E\u0449\u0438\u043C\u0441\u044F
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u043C \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u0438 \u0441\u0442\u0440\u0435\u043C\u044F\u0441\u044C \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C
    \u0441\u0442\u0430\u0442\u0443\u0441 \u043A\u0438\u043D\u043E\u0441\u0442\u0443\u0434\u0438\u0438
    \u043A\u0430\u043A \u0446\u0435\u043D\u0442\u0440\u0430 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043D\u043E\u0439
    \u0438 \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u043E\u0439 \u0436\u0438\u0437\u043D\u0438
    \u0421\u0430\u043D\u043A\u0442-\u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0430."
  noteUIPanel: {fileID: 1310590339}
  noteUIText: {fileID: 920439398}
