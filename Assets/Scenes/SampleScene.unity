--- !u!114 &1091325851
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1091325849}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b278067e024271f43b100a741f1ba21f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  noteText: "\xAB\u041B\u0435\u043D\u0444\u0438\u043B\u044C\u043C\xBB \u2014 \u043E\u0434\u043D\u0430
    \u0438\u0437 \u0441\u0442\u0430\u0440\u0435\u0439\u0448\u0438\u0445 \u043A\u0438\u043D\u043E\u0441\u0442\u0443\u0434\u0438\u0439
    \u0420\u043E\u0441\u0441\u0438\u0438, \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043D\u0430\u0447\u0430\u043B\u0430\u0441\u044C
    \u0432 1914 \u0433\u043E\u0434\u0443 \u0432 \u041F\u0435\u0442\u0440\u043E\u0433\u0440\u0430\u0434\u0435
    \u0441 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F \u0447\u0430\u0441\u0442\u043D\u043E\u0439
    \u043A\u0438\u043D\u043E\u0444\u0430\u0431\u0440\u0438\u043A\u0438 \xAB\u0425\u0430\u043D\u0436\u043E\u043D\u043A\u043E\u0432
    \u0438 \u041A\u043E\xBB. \u0412 1918 \u0433\u043E\u0434\u0443, \u043F\u043E\u0441\u043B\u0435
    \u041E\u043A\u0442\u044F\u0431\u0440\u044C\u0441\u043A\u043E\u0439 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438,
    \u0441\u0442\u0443\u0434\u0438\u044F \u0431\u044B\u043B\u0430 \u043D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u0430
    \u0438 \u0441\u0442\u0430\u043B\u0430 \u043D\u0430\u0437\u044B\u0432\u0430\u0442\u044C\u0441\u044F
    \u041F\u0435\u0442\u0440\u043E\u0433\u0440\u0430\u0434\u0441\u043A\u0438\u043C
    \u043A\u0438\u043D\u043E\u043A\u043E\u043C\u0438\u0442\u0435\u0442\u043E\u043C.
    \u0412 1920-\u0435 \u0433\u043E\u0434\u044B \u043E\u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u043B\u0430\u0441\u044C
    \u043A\u0430\u043A \u043E\u0434\u043D\u0430 \u0438\u0437 \u0433\u043B\u0430\u0432\u043D\u044B\u0445
    \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u0438\u0445 \u0441\u0442\u0443\u0434\u0438\u0439,
    \u0432\u044B\u043F\u0443\u0441\u043A\u0430\u044F \u043A\u0430\u043A \u0445\u0443\u0434\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435,
    \u0442\u0430\u043A \u0438 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0444\u0438\u043B\u044C\u043C\u044B. \u0412 1934 \u0433\u043E\u0434\u0443 \u043A\u0438\u043D\u043E\u0441\u0442\u0443\u0434\u0438\u044F
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435
    \xAB\u041B\u0435\u043D\u0444\u0438\u043B\u044C\u043C\xBB. \u0412\u043E \u0432\u0440\u0435\u043C\u044F
    \u0412\u0435\u043B\u0438\u043A\u043E\u0439 \u041E\u0442\u0435\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u0447\u0430\u0441\u0442\u044C \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u0432
    \u0438 \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    \u0431\u044B\u043B\u0430 \u044D\u0432\u0430\u043A\u0443\u0438\u0440\u043E\u0432\u0430\u043D\u0430,
    \u043D\u043E \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u043E
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B\u043E\u0441\u044C \u0432
    \u044D\u0432\u0430\u043A\u0443\u0430\u0446\u0438\u0438. \u0412 \u043F\u043E\u0441\u043B\u0435\u0432\u043E\u0435\u043D\u043D\u044B\u0435
    \u0433\u043E\u0434\u044B \u0441\u0442\u0443\u0434\u0438\u044F \u043F\u0435\u0440\u0435\u0436\u0438\u043B\u0430
    \u0440\u0430\u0441\u0446\u0432\u0435\u0442, \u0432\u044B\u043F\u0443\u0441\u043A\u0430\u044F
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u0444\u0438\u043B\u044C\u043C\u044B,
    \u0441\u0442\u0430\u0432\u0448\u0438\u0435 \u0447\u0430\u0441\u0442\u044C\u044E
    \u0437\u043E\u043B\u043E\u0442\u043E\u0433\u043E \u0444\u043E\u043D\u0434\u0430
    \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u043E\u0433\u043E \u043A\u0438\u043D\u043E.
    \u041D\u0430 \xAB\u041B\u0435\u043D\u0444\u0438\u043B\u044C\u043C\u0435\xBB \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438
    \u0442\u0430\u043A\u0438\u0435 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F
    \u0440\u0435\u0436\u0438\u0441\u0441\u0451\u0440\u044B, \u043A\u0430\u043A \u0421\u0435\u0440\u0433\u0435\u0439
    \u042D\u0439\u0437\u0435\u043D\u0448\u0442\u0435\u0439\u043D, \u0413\u0440\u0438\u0433\u043E\u0440\u0438\u0439
    \u041A\u043E\u0437\u0438\u043D\u0446\u0435\u0432, \u0410\u043B\u0435\u043A\u0441\u0435\u0439
    \u0413\u0435\u0440\u043C\u0430\u043D. \u041A\u0438\u043D\u043E\u0441\u0442\u0443\u0434\u0438\u044F
    \u0441\u044B\u0433\u0440\u0430\u043B\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u0443\u044E
    \u0440\u043E\u043B\u044C \u0432 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0438
    \u043E\u0442\u0435\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u043A\u0438\u043D\u0435\u043C\u0430\u0442\u043E\u0433\u0440\u0430\u0444\u0430,
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0432 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043D\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u0434\u043E \u043D\u0430\u0448\u0438\u0445
    \u0434\u043D\u0435\u0439 \u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C \u043A\u0430\u043A \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u0438\u0439
    \u0446\u0435\u043D\u0442\u0440 \u043A\u0438\u043D\u043E\u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430."
  noteUIPanel: {fileID: 1310590339}
  noteUIText: {fileID: 920439398}
