  noteText: "\u0412 \u0433\u043E\u0434\u044B \u0412\u0435\u043B\u0438\u043A\u043E\u0439
    \u041E\u0442\u0435\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u043A\u0438\u043D\u043E\u0441\u0442\u0443\u0434\u0438\u044F
