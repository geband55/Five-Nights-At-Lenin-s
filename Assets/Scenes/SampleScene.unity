--- !u!114 &970468427
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 970468424}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b278067e024271f43b100a741f1ba21f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  noteText: "\u0421 \u043D\u0430\u0447\u0430\u043B\u043E\u043C \u0412\u0435\u043B\u0438\u043A\u043E\u0439
    \u041E\u0442\u0435\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u0432 1941 \u0433\u043E\u0434\u0443 \u043A\u0438\u043D\u043E\u0441\u0442\u0443\u0434\u0438\u044F
    \xAB\u041B\u0435\u043D\u0444\u0438\u043B\u044C\u043C\xBB \u043D\u0430\u0447\u0430\u043B\u0430
    \u0441\u0440\u043E\u0447\u043D\u0443\u044E \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0443
    \u043A \u044D\u0432\u0430\u043A\u0443\u0430\u0446\u0438\u0438. \u0418\u0437-\u0437\u0430
    \u0443\u0433\u0440\u043E\u0437\u044B \u0431\u043E\u043C\u0431\u0451\u0436\u0435\u043A
    \u0438 \u043D\u0430\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F \u0432\u0440\u0430\u0433\u0430
    \u0441\u0442\u0430\u043B\u043E \u044F\u0441\u043D\u043E, \u0447\u0442\u043E \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0442\u044C
    \u0440\u0430\u0431\u043E\u0442\u0443 \u0432 \u041B\u0435\u043D\u0438\u043D\u0433\u0440\u0430\u0434\u0435
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E. \u041F\u043E \u043F\u0440\u0438\u043A\u0430\u0437\u0443
    \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u043D\u0430\u0447\u0430\u043B\u0441\u044F \u0432\u044B\u0432\u043E\u0437 \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u044F,
    \u043A\u0438\u043D\u043E\u0430\u0440\u0445\u0438\u0432\u043E\u0432 \u0438 \u043D\u0435\u0437\u0430\u0432\u0435\u0440\u0448\u0451\u043D\u043D\u044B\u0445
    \u0444\u0438\u043B\u044C\u043C\u043E\u0432. \u041E\u0441\u043D\u043E\u0432\u043D\u0443\u044E
    \u0447\u0430\u0441\u0442\u044C \u043A\u043E\u043B\u043B\u0435\u043A\u0442\u0438\u0432\u0430
    \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0438 \u0432 \u0410\u043B\u043C\u0430-\u0410\u0442\u0443,
    \u0433\u0434\u0435 \u0441\u0442\u0443\u0434\u0438\u044F \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B\u0430
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u043D\u0430
    \u0431\u0430\u0437\u0435 \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0451\u043D\u043D\u043E\u0439
    \u043A\u0438\u043D\u043E\u0441\u0442\u0443\u0434\u0438\u0438.  \u042D\u0432\u0430\u043A\u0443\u0430\u0446\u0438\u044F
    \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u043B\u0430 \u0432 \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445: \u043D\u0435 \u0445\u0432\u0430\u0442\u0430\u043B\u043E
    \u0442\u0440\u0430\u043D\u0441\u043F\u043E\u0440\u0442\u0430, \u0448\u043B\u0438
    \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u044B\u0435 \u043D\u0430\u043B\u0451\u0442\u044B.
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u044D\u0442\u043E,
    \u0442\u0435\u0445\u043D\u0438\u043A\u0443 \u0438 \u043A\u0430\u0434\u0440\u044B
    \u0443\u0434\u0430\u043B\u043E\u0441\u044C \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C.
    \u0427\u0430\u0441\u0442\u044C \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u0432
    \u043E\u0441\u0442\u0430\u043B\u0430\u0441\u044C \u0432 \u041B\u0435\u043D\u0438\u043D\u0433\u0440\u0430\u0434\u0435
    \u0438 \u0441\u043D\u0438\u043C\u0430\u043B\u0430 \u0444\u0440\u043E\u043D\u0442\u043E\u0432\u0443\u044E
    \u0445\u0440\u043E\u043D\u0438\u043A\u0443.  \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0431\u044B\u0441\u0442\u0440\u043E\u0439 \u0438 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u044D\u0432\u0430\u043A\u0443\u0430\u0446\u0438\u0438 \xAB\u041B\u0435\u043D\u0444\u0438\u043B\u044C\u043C\xBB
    \u0432\u044B\u0436\u0438\u043B \u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B
    \u0441\u043D\u0438\u043C\u0430\u0442\u044C \u0444\u0438\u043B\u044C\u043C\u044B
    \u0434\u0430\u0436\u0435 \u0432 \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445
    \u0432\u043E\u0439\u043D\u044B. \u042D\u0442\u043E\u0442 \u044D\u0442\u0430\u043F
    \u0441\u0442\u0430\u043B \u0432\u0430\u0436\u043D\u044B\u043C \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u043C
    \u0441\u0442\u043E\u0439\u043A\u043E\u0441\u0442\u0438 \u0438 \u043F\u0440\u0435\u0434\u0430\u043D\u043D\u043E\u0441\u0442\u0438
    \u0434\u0435\u043B\u0443 \u043A\u0438\u043D\u043E."
  noteUIPanel: {fileID: 1310590339}
  noteUIText: {fileID: 920439398}
