    \u0431\u043B\u043E\u043A\u0430\u0434\u043D\u043E\u0433\u043E \u041B\u0435\u043D\u0438\u043D\u0433\u0440\u0430\u0434\u0430.
    \u0412 1941 \u0433\u043E\u0434\u0443 \u043E\u0441\u043D\u043E\u0432\u043D\u0443\u044E
    \u0447\u0430\u0441\u0442\u044C \u043A\u043E\u043B\u043B\u0435\u043A\u0442\u0438\u0432\u0430
    \u0438 \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u0435
    \u043F\u0435\u0440\u0435\u0432\u0435\u0437\u043B\u0438 \u0432 \u0410\u043B\u043C\u0430-\u0410\u0442\u0443,
    \u0433\u0434\u0435 \u043D\u0430 \u0431\u0430\u0437\u0435 \u0426\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439
    \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0451\u043D\u043D\u043E\u0439 \u043A\u0438\u043D\u043E\u0441\u0442\u0443\u0434\u0438\u0438
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438 \u0432\u043C\u0435\u0441\u0442\u0435
    \u0441 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438 \u0438\u0437 \u0434\u0440\u0443\u0433\u0438\u0445
    \u0441\u0442\u0443\u0434\u0438\u0439 \u0441\u0442\u0440\u0430\u043D\u044B. \u0417\u0434\u0435\u0441\u044C
    \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u043B\u0438\u0441\u044C \u0430\u0433\u0438\u0442\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0435
    \u0444\u0438\u043B\u044C\u043C\u044B, \u0445\u0440\u043E\u043D\u0438\u043A\u0430,
    \u0432\u043E\u0435\u043D\u043D\u044B\u0435 \u0434\u0440\u0430\u043C\u044B, \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u0435
    \u043D\u0430 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0443 \u0431\u043E\u0435\u0432\u043E\u0433\u043E
    \u0434\u0443\u0445\u0430 \u0444\u0440\u043E\u043D\u0442\u0430 \u0438 \u0442\u044B\u043B\u0430.
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0442\u044F\u0436\u0451\u043B\u044B\u0435
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F, \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u043D\u0435
    \u043F\u0440\u0435\u043A\u0440\u0430\u0449\u0430\u043B\u0430\u0441\u044C. \u0412
    \u0442\u043E \u0436\u0435 \u0432\u0440\u0435\u043C\u044F \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u0430\u044F
    \u0433\u0440\u0443\u043F\u043F\u0430 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u0432
    \u043E\u0441\u0442\u0430\u043B\u0430\u0441\u044C \u0432 \u043E\u0441\u0430\u0436\u0434\u0451\u043D\u043D\u043E\u043C
    \u0433\u043E\u0440\u043E\u0434\u0435, \u0433\u0434\u0435 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B\u0430
    \u0441\u043D\u0438\u043C\u0430\u0442\u044C \u0444\u0440\u043E\u043D\u0442\u043E\u0432\u044B\u0435
    \u043A\u0438\u043D\u043E\u0436\u0443\u0440\u043D\u0430\u043B\u044B \u0438 \u0445\u0440\u043E\u043D\u0438\u043A\u0443
    \u0431\u043B\u043E\u043A\u0430\u0434\u044B.  \u041F\u043E\u0441\u043B\u0435 \u0441\u043D\u044F\u0442\u0438\u044F
    \u0431\u043B\u043E\u043A\u0430\u0434\u044B \u0432 1944 \u0433\u043E\u0434\u0443
    \u043D\u0430\u0447\u0430\u043B\u043E\u0441\u044C \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u043A\u043E\u043B\u043B\u0435\u043A\u0442\u0438\u0432\u0430 \u0432 \u041B\u0435\u043D\u0438\u043D\u0433\u0440\u0430\u0434.
    \u0421\u0442\u0443\u0434\u0438\u044E \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0438,
    \u0438 \u0443\u0436\u0435 \u043A 1945 \u0433\u043E\u0434\u0443 \xAB\u041B\u0435\u043D\u0444\u0438\u043B\u044C\u043C\xBB
    \u0441\u043D\u043E\u0432\u0430 \u043D\u0430\u0447\u0430\u043B \u043F\u043E\u043B\u043D\u043E\u0446\u0435\u043D\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u0432 \u0440\u043E\u0434\u043D\u043E\u043C
    \u0433\u043E\u0440\u043E\u0434\u0435. \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    \u0441\u0442\u0430\u043B \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C \u0441\u0442\u043E\u0439\u043A\u043E\u0441\u0442\u0438
    \u0438 \u043F\u0440\u0435\u0434\u0430\u043D\u043D\u043E\u0441\u0442\u0438 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0443:
    \u0434\u0430\u0436\u0435 \u0432 \u0441\u0430\u043C\u044B\u0435 \u0442\u044F\u0436\u0451\u043B\u044B\u0435
    \u0433\u043E\u0434\u044B \u043B\u0435\u043D\u0444\u0438\u043B\u044C\u043C\u043E\u0432\u0446\u044B
    \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u043B\u0438 \u0441\u0432\u044F\u0437\u044C
    \u0441 \u0440\u043E\u0434\u043D\u044B\u043C \u0433\u043E\u0440\u043E\u0434\u043E\u043C
    \u0438 \u0434\u0435\u043B\u043E\u043C \u0432\u0441\u0435\u0439 \u0436\u0438\u0437\u043D\u0438."
  noteUIPanel: {fileID: 1310590339}
  noteUIText: {fileID: 920439398}
